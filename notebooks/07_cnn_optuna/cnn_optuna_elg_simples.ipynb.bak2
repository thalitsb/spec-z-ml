    "from config import paths_for, RESULTS_DIR, MODELS_DIR\n",
    "# - paths_for(\"ELG\") -> dicionario com todos os caminhos de arquivos do ELG\n",
    "# - RESULTS_DIR e MODELS_DIR sao Path objects apontando pra pastas no projeto\n",
    "\n",
    "from src.data import load_spectral_dataset, normalize_spectra\n",
    "# - load_spectral_dataset(arquivo.h5) -> (X, y, n_wave): le HDF5 e devolve arrays\n",
    "# - normalize_spectra(X) -> X normalizado pelo max-abs de cada linha\n",
