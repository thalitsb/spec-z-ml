    "# ============================================================\n",
    "# PAPERMILL PARAMETERS\n",
    "# ============================================================\n",
    "# Esta celula esta TAGEADA como `parameters` (veja menu Cell > Tags no Jupyter,\n",
    "# ou metadata do notebook). Papermill substitui essas variaveis quando o\n",
    "# notebook e executado via CLI:\n",
    "#\n",
    "#     papermill cnn_optuna_elg_simples.ipynb out.ipynb \\\n",
    "#         -p N_TRIALS 100 -p SEED 7\n",
    "#\n",
    "# Rodando manualmente (sem papermill), os defaults abaixo sao usados.\n",
    "\n",
    "OBJECT_TYPE      = \"ELG\"      # \"LRG\" | \"ELG\" | \"QSO\"\n",
    "SEED             = 42         \n",
    "N_TRIALS         = 50         # numero de trials do Optuna\n",
    "EPOCHS_PER_TRIAL = 25         # max epocas por trial (early stop e pruner cortam antes)\n",
    "FINAL_EPOCHS     = 80         # epocas no retreino final (com os melhores HPs)\n"
   ]
  },
