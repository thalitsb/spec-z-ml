   "source": [
    "# ============================================================\n",
    "# IMPORTS BASICOS\n",
    "# ============================================================\n",
    "\n",
    "# `sys` mexe com o caminho de busca do Python (pra achar nossos modulos do projeto).\n",
    "import sys\n",
    "\n",
    "# `pathlib.Path` representa caminhos de arquivos de forma robusta (Linux/Windows).\n",
    "from pathlib import Path\n",
    "\n",
    "# NumPy: arrays numericos rapidos. Toda a manipulacao numerica passa por ele.\n",
    "import numpy as np\n",
    "\n",
