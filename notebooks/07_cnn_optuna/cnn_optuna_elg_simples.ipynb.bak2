    "import pandas as pd\n",
    "\n",
    "# Matplotlib: graficos. Seaborn: melhora o estilo dos graficos.\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "\n",
    "\n",
    "# ============================================================\n",
    "# DESCOBRIR A RAIZ DO PROJETO (onde mora o config.py)\n",
    "# ============================================================\n",
    "# Notebook esta em: spec_z_ml/notebooks/07_cnn_optuna/\n",
    "# config.py esta em: spec_z_ml/\n",
    "# Subimos ate achar config.py.\n",
    "\n",
    "NOTEBOOK_DIR = Path.cwd()                # diretorio onde o notebook foi aberto\n",
    "PROJECT_ROOT = NOTEBOOK_DIR              # comecamos a busca aqui\n",
    "\n",
    "# Sobe um nivel ate encontrar config.py (ou ate chegar na raiz do disco)\n",
    "while not (PROJECT_ROOT / \"config.py\").exists() and PROJECT_ROOT != PROJECT_ROOT.parent:\n",
    "    PROJECT_ROOT = PROJECT_ROOT.parent\n",
