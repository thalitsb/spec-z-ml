  {
   "cell_type": "code",
   "execution_count": null,
   "id": "40a5107a",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ============================================================\n",
    "# DIAGNOSTICO AVANCADO: metricas binadas + distribuicoes\n",
    "# ============================================================\n",
    "# Os plots anteriores (cell 23) mostram a performance GLOBAL.\n",
    "# Aqui investigamos COMO A PERFORMANCE VARIA com z:\n",
    "#\n",
    "#   (a) sigma_NMAD por bin de z   \u2014 em que faixa de z o modelo eh preciso?\n",
    "#   (b) bias por bin de z          \u2014 ha vies sistematico em alguma faixa?\n",
    "#   (c) % outliers por bin de z   \u2014 onde os catastroficos se concentram?\n",
    "#   (d) distribuicao z_real vs z_pred sobrepostas \u2014 regressao a media?\n",
    "#\n",
    "# Para um TCC de spec-z, estes plots sao essenciais pra discussao.\n",
    "\n",
    "plot_dir = RESULTS_DIR / OBJECT_TYPE / \"cnn_optuna_simples\" / \"plots\"\n",
    "plot_dir.mkdir(parents=True, exist_ok=True)\n",
    "\n",
    "\n",
    "# ============================================================\n",
    "# CALCULAR METRICAS BINADAS POR z\n",
    "# ============================================================\n",
    "n_bins = 10\n",
    "bin_edges  = np.linspace(float(y_test.min()), float(y_test.max()), n_bins + 1)\n",
    "bin_centers = 0.5 * (bin_edges[:-1] + bin_edges[1:])\n",
    "\n",
    "# np.digitize devolve indice do bin pra cada amostra (1-indexed); subtrai 1.\n",
    "bin_idx = np.clip(np.digitize(y_test, bin_edges) - 1, 0, n_bins - 1)\n",
    "\n",
    "sigma_per_bin = np.full(n_bins, np.nan)\n",
    "bias_per_bin  = np.full(n_bins, np.nan)\n",
    "out05_per_bin = np.full(n_bins, np.nan)\n",
    "out15_per_bin = np.full(n_bins, np.nan)\n",
    "n_per_bin     = np.zeros(n_bins, dtype=int)\n",
    "\n",
    "MIN_PER_BIN = 10  # bins com menos amostras sao deixados como NaN (pouco estatistica)\n",
    "for b in range(n_bins):\n",
    "    mask = bin_idx == b\n",
    "    n_per_bin[b] = int(mask.sum())\n",
    "    if n_per_bin[b] < MIN_PER_BIN:\n",
    "        continue\n",
    "    dz_b   = delta_z[mask]\n",
    "    b_bias = float(np.median(dz_b))\n",
    "    sigma_per_bin[b] = 1.4826 * float(np.median(np.abs(dz_b - b_bias)))\n",
    "    bias_per_bin[b]  = b_bias\n",
    "    out05_per_bin[b] = 100.0 * float(np.mean(np.abs(dz_b) > 0.05))\n",
    "    out15_per_bin[b] = 100.0 * float(np.mean(np.abs(dz_b) > 0.15))\n",
    "\n",
    "\n",
    "# ============================================================\n",
    "# PLOTAR\n",
    "# ============================================================\n",
    "fig, axes = plt.subplots(2, 2, figsize=(14, 10))\n",
    "\n",
    "# --- (a) sigma_NMAD por bin de z ---\n",
    "axes[0, 0].plot(bin_centers, sigma_per_bin, \"o-\", lw=2, color=\"steelblue\")\n",
    "axes[0, 0].axhline(sigma_nmad, color=\"red\", lw=1, ls=\"--\",\n",
    "                   label=f\"global = {sigma_nmad:.4f}\")\n",
    "axes[0, 0].set_xlabel(\"z_real (centro do bin)\")\n",
    "axes[0, 0].set_ylabel(\"sigma_NMAD\")\n",
    "axes[0, 0].set_title(\"(a) sigma_NMAD por bin de z\")\n",
    "axes[0, 0].legend()\n",
    "axes[0, 0].grid(alpha=0.3)\n",
    "\n",
    "# --- (b) bias por bin de z ---\n",
    "axes[0, 1].plot(bin_centers, bias_per_bin, \"o-\", lw=2, color=\"darkorange\")\n",
    "axes[0, 1].axhline(0, color=\"gray\", lw=1, ls=\"-\")\n",
    "axes[0, 1].axhline(bias, color=\"red\", lw=1, ls=\"--\", label=f\"global = {bias:+.4f}\")\n",
    "axes[0, 1].set_xlabel(\"z_real (centro do bin)\")\n",
    "axes[0, 1].set_ylabel(\"bias = mediana(\u0394z/(1+z))\")\n",
    "axes[0, 1].set_title(\"(b) Bias por bin de z\")\n",
    "axes[0, 1].legend()\n",
    "axes[0, 1].grid(alpha=0.3)\n",
    "\n",
    "# --- (c) % outliers por bin de z ---\n",
    "axes[1, 0].plot(bin_centers, out05_per_bin, \"o-\", lw=2, color=\"darkred\",   label=\"|\u0394z/(1+z)| > 0.05\")\n",
    "axes[1, 0].plot(bin_centers, out15_per_bin, \"s-\", lw=2, color=\"firebrick\", label=\"|\u0394z/(1+z)| > 0.15\")\n",
    "axes[1, 0].axhline(outliers_05, color=\"darkred\",   lw=1, ls=\"--\", alpha=0.5,\n",
    "                   label=f\"global 0.05 = {outliers_05:.2f}%\")\n",
    "axes[1, 0].axhline(outliers_15, color=\"firebrick\", lw=1, ls=\"--\", alpha=0.5,\n",
    "                   label=f\"global 0.15 = {outliers_15:.2f}%\")\n",
    "axes[1, 0].set_xlabel(\"z_real (centro do bin)\")\n",
    "axes[1, 0].set_ylabel(\"% outliers no bin\")\n",
    "axes[1, 0].set_title(\"(c) Outliers por bin de z\")\n",
    "axes[1, 0].legend(fontsize=9)\n",
    "axes[1, 0].grid(alpha=0.3)\n",
    "\n",
    "# Eixo secundario com contagem de objetos no bin (transparente)\n",
    "axb = axes[1, 0].twinx()\n",
    "axb.bar(bin_centers, n_per_bin, width=(bin_edges[1]-bin_edges[0])*0.9,\n",
    "        color=\"gray\", alpha=0.15, zorder=0)\n",
    "axb.set_ylabel(\"# galaxias (cinza)\", color=\"gray\")\n",
    "axb.tick_params(axis=\"y\", colors=\"gray\")\n",
    "\n",
    "# --- (d) Distribuicao z_real vs z_pred (regressao a media?) ---\n",
    "# Se z_pred for mais estreita que z_real (espremida pro centro),\n",
    "# o modelo esta sofrendo regressao a media.\n",
    "bins_d = np.linspace(float(y_test.min()), float(y_test.max()), 50)\n",
    "axes[1, 1].hist(y_test,      bins=bins_d, alpha=0.55, color=\"steelblue\",\n",
    "                label=\"z_real\",    edgecolor=\"black\", lw=0.3)\n",
    "axes[1, 1].hist(y_pred_test, bins=bins_d, alpha=0.55, color=\"darkorange\",\n",
    "                label=\"z_predito\", edgecolor=\"black\", lw=0.3)\n",
    "axes[1, 1].set_xlabel(\"z\")\n",
    "axes[1, 1].set_ylabel(\"# galaxias\")\n",
    "axes[1, 1].set_title(\"(d) Distribuicao z_real vs z_predito\")\n",
    "axes[1, 1].legend()\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig(plot_dir / \"model_final_diagnostics.png\", dpi=150, bbox_inches=\"tight\")\n",
    "plt.show()\n",
    "print(f\"Salvo: {plot_dir / 'model_final_diagnostics.png'}\")\n",
    "\n",
    "\n",
    "# ============================================================\n",
    "# TABELA RESUMO POR BIN (util pra anexar no relatorio)\n",
    "# ============================================================\n",
    "diag_df = pd.DataFrame({\n",
    "    \"z_min\":        bin_edges[:-1],\n",
    "    \"z_max\":        bin_edges[1:],\n",
    "    \"n_galaxias\":   n_per_bin,\n",
    "    \"sigma_nmad\":   sigma_per_bin,\n",
    "    \"bias\":         bias_per_bin,\n",
    "    \"outliers_05_%\": out05_per_bin,\n",
    "    \"outliers_15_%\": out15_per_bin,\n",
    "})\n",
    "diag_df.to_csv(plot_dir.parent / \"metrics_per_z_bin.csv\", index=False)\n",
    "print(f\"Salvo: {plot_dir.parent / 'metrics_per_z_bin.csv'}\")\n",
    "print(\"\\nResumo por bin:\")\n",
    "print(diag_df.round(4))\n"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 11. Salvar tudo\n",
    "\n",
    "Salva o modelo treinado, as predicoes e os hiperparametros em disco. Isso e essencial pra:\n",
    "- Reproduzir resultados depois\n",
    "- Comparar com outros modelos (baseline, XGBoost, etc.)\n",
    "- Anexar no relatorio/paper"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ============================================================\n",
    "# DEFINIR ONDE SALVAR\n",
    "# ============================================================\n",
    "out_dir   = RESULTS_DIR / OBJECT_TYPE / \"cnn_optuna_simples\"   # resultados (npz, json)\n",
    "model_dir = MODELS_DIR  / OBJECT_TYPE / \"cnn_optuna_simples\"   # modelo treinado\n",
    "out_dir.mkdir(parents=True, exist_ok=True)\n",
    "model_dir.mkdir(parents=True, exist_ok=True)\n",
    "\n",
    "\n",
    "# ============================================================\n",
    "# SALVAR O MODELO\n",
    "# ============================================================\n",
    "# Formato .keras: arquivo unico, contem arquitetura + pesos.\n",
    "# Pra carregar depois: keras.models.load_model(\"...keras\")\n",
    "best_model.save(model_dir / \"best_model.keras\")\n",
    "\n",
    "\n",
    "# ============================================================\n",
    "# SALVAR PREDICOES (.npz = formato eficiente do NumPy pra arrays)\n",
    "# ============================================================\n",
    "# Pra carregar depois: data = np.load(\"predictions.npz\"); y_test = data[\"y_test\"]\n",
    "np.savez(\n",
    "    out_dir / \"predictions.npz\",\n",
    "    y_test=y_test,\n",
    "    y_pred=y_pred_test,\n",
    "    delta_z=delta_z,\n",
    ")\n",
    "\n",
    "\n",
    "# ============================================================\n",
    "# SALVAR METRICAS + MELHORES HPs (JSON, formato legivel humano)\n",
    "# ============================================================\n",
    "import json as _json\n",
    "\n",
    "resultados = {\n",
    "    \"best_params\": study.best_params,            # melhores HPs\n",
    "    \"best_val_mae\": float(study.best_value),     # val_MAE do melhor trial\n",
    "    \"n_trials\": len(study.trials),               # quantos trials rodaram\n",
    "    \"test_metrics\": {                            # metricas no test\n",
    "        \"mae\":         float(mae),\n",
    "        \"bias\":        float(bias),\n",
    "        \"sigma_nmad\":  float(sigma_nmad),\n",
    "        \"outliers_05\": float(outliers_05),\n",
    "        \"outliers_15\": float(outliers_15),\n",
    "    },\n",
    "}\n",
    "\n",
    "with open(out_dir / \"results.json\", \"w\") as f:\n",
    "    _json.dump(resultados, f, indent=2)\n",
    "\n",
    "\n",
    "# ============================================================\n",
    "# CONFIRMAR\n",
